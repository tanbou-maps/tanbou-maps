# app/views/reviews/new.html.erb
<div class="review-form-container">
  <h1><%= @spot.name %>のレビュー投稿</h1>

  <%= form_with model: [@spot, @review], local: true do |f| %>
    <% if @review.errors.any? %>
      <div class="error-messages">
        <ul>
          <% @review.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :title, 'タイトル' %>
      <%= f.text_field :title, class: 'form-control', required: true %>
    </div>

    <div class="form-group">
      <%= f.label :rating, '評価' %>
      <%= f.select :rating,
          options_for_select((1..5).map { |n| [("★" * n), n] }),
          { prompt: '評価を選択してください' },
          { class: 'form-control', required: true } %>
    </div>

    <div class="form-group">
      <%= f.label :content, 'レビュー内容' %>
      <%= f.text_area :content, class: 'form-control', rows: 5, required: true %>
    </div>

    <div class="form-group">
      <%= f.label :images, '画像（最大5枚まで）' %>
      <%= f.file_field :images, class: 'form-control', required: true, accept: 'image/jpeg,image/png', multiple: true %>
      <small class="form-text text-muted">
        ※JPEGまたはPNG形式、1枚あたり5MB以下の画像をアップロードしてください
      </small>
    </div>

    <%= f.submit '投稿する', class: 'submit-button' %>
  <% end %>
</div>
